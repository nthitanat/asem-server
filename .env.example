# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=asem_db
DB_USER=root
DB_PASSWORD=your_password
DB_CONNECTION_LIMIT=20

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-this-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Token Expiry (in seconds)
EMAIL_VERIFICATION_EXPIRY=86400    # 24 hours
PASSWORD_RESET_EXPIRY=3600         # 1 hour

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@asem.com
FROM_NAME=ASEM Server

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Security Configuration
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000                          # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000                      # 15 minutes
AUTH_RATE_LIMIT_MAX_REQUESTS=10                       # skips successful requests
PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=3600000           # 1 hour
PASSWORD_RESET_RATE_LIMIT_MAX_REQUESTS=3
EMAIL_VERIFICATION_RATE_LIMIT_WINDOW_MS=3600000       # 1 hour
EMAIL_VERIFICATION_RATE_LIMIT_MAX_REQUESTS=5

# CORS Configuration (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Internal Service API Key (used by asem-mailer to call /internal/v1 endpoints)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_KEY=change-this-to-a-secure-random-key
